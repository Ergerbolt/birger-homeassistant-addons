{
  "name": "Daly WNT BMS MQTT Bridge (Waveshare RS485/TCP)",
  "version": "1.1.22",
  "slug": "dalybms_waveshare",
  "description": "Reads Daly WNT BMS data via Waveshare RS485-to-Ethernet converter and publishes to MQTT for Home Assistant",
  "startup": "application",
  "boot": "auto",
  "init": false,
  "arch": [
    "amd64",
    "aarch64",
    "armv7"
  ],
  "options": {
    "mqtt_server": "core-mosquitto",
    "mqtt_user": "",
    "mqtt_pass": "",
    "mqtt_client_id": "dalybms_waveshare",
    "mqtt_discovery_prefix": "homeassistant",
    "device": "bms.local",
    "device_id": "WNT-BMS",
    "cells_in_series": 16,
    "nominal_capacity_ah": 0,
    "poll_interval_seconds": 10,
    "modbus_port": 502,
